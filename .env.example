# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# data.gov.in Open Government Data API
DATA_GOV_IN_API_KEY=your_data_gov_in_key_here

# Google APIs (Places, Air Quality, Geocoding)
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Admin panel
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_JWT_SECRET=choose_a_long_random_secret_string
CRON_SECRET=choose_a_long_random_secret_string

# User auth (can be any long random string; has insecure default if omitted)
USER_JWT_SECRET=choose_a_long_random_secret_string

# Anthropic Claude API — document extraction for community contributions (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Groq API — article summary agent (free at console.groq.com, no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Firebase Firestore (project ID only — web config is in firestore.ts)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PROJECT_ID=your_firebase_project_id
