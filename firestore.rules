rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public read-only collections ───────────────────────────────────────
    // PHI intelligence items that are marked "live" are publicly readable.
    match /ph_intelligence/{docId} {
      allow read: if resource.data.status == "live";
      allow write: if false; // server-side only via service account
    }

    // IDSP weekly cache is public read (no PII).
    match /idsp_weekly/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ph_cache is public read.
    match /ph_cache/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── User-writable, own-record-only ────────────────────────────────────
    // Users can only read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Server-side only (no client access) ───────────────────────────────
    match /waitlist/{docId}             { allow read, write: if false; }
    match /pendingSubmissions/{docId}   { allow read, write: if false; }
    match /feedback/{docId}             { allow read, write: if false; }
    match /hospitals/{docId}            { allow read: if true; allow write: if false; }
    match /health_locker_files/{docId}  { allow read, write: if false; }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
